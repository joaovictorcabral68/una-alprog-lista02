programa {
  inteiro saldodisponivel
  inteiro saque
  inteiro saldo

  funcao inicio() {
    escreva("Seu saldo é de:")
    leia(saldodisponivel)
    escreva("Quanto deseja sacar?")
    leia(saque)
    se (saldodisponivel>saque)
    saldo=saldodisponivel-saque
    escreva("Seu saldo é de:"+saldo)
    leia(saldo)
  
   
  
    


   

    
  }
}
